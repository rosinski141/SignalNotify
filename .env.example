# Telegram API credentials (get from https://my.telegram.org)
TELEGRAM_API_ID=123123
TELEGRAM_API_HASH=12321321312321321312

# Telegram channels to monitor (comma-separated channel usernames or IDs)
# e.g. channel1,channel2,-1001234567890
TELEGRAM_CHANNELS=channel1,channel2,-1001234567890

# MT5 terminal executable path
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# How often to check prices (seconds)
PRICE_CHECK_INTERVAL=1

# How often to check if messages still exist (seconds)
MESSAGE_CHECK_INTERVAL=1
